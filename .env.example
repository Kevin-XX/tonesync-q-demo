# ============================================
# 腾讯混元大模型 API 配置
# ============================================
# 
# 获取方式：
# 1. 访问腾讯云控制台 https://console.cloud.tencent.com/
# 2. 搜索并开通「混元大模型」服务
# 3. 进入「API密钥管理」获取 SecretId 和 SecretKey
#
# 文档地址：https://cloud.tencent.com/document/product/1729

# 腾讯云 SecretId（替换为你的实际值）
VITE_TENCENT_SECRET_ID=your_secret_id_here

# 腾讯云 SecretKey（替换为你的实际值）
VITE_TENCENT_SECRET_KEY=your_secret_key_here

# 地域（默认广州，可选：ap-guangzhou, ap-shanghai, ap-beijing 等）
VITE_TENCENT_REGION=ap-guangzhou

# 混元模型（可选：hunyuan-turbo, hunyuan-turbos-latest, hunyuan-t1）
# hunyuan-turbo: 高速模型，响应快
# hunyuan-turbos-latest: 最新旗舰模型，能力更强
# hunyuan-t1: 思考模型，适合复杂推理
VITE_HUNYUAN_MODEL=hunyuan-turbo
